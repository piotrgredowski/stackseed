"""Command line interface for {{ project_name }}."""

from __future__ import annotations

import argparse
from collections.abc import Sequence
import logging
from pathlib import Path
import time

from .calculator import add

APPLICATION_NAME = "{{ project_slug }}"
LOGS_DIRECTORY = "logs"
LOG_FILE_NAME = f"{APPLICATION_NAME}.log"
LOG_FORMAT = "%(asctime)s %(levelname)s [%(name)s] %(message)s"
{% if config_enabled == "true" %}
CONFIG_DIRECTORY = "config"
CONFIG_FILE_NAME = f"{APPLICATION_NAME}.toml"
{% endif %}
logger = logging.getLogger(APPLICATION_NAME)


def project_root() -> Path:
    """Return the generated project root independent of the current directory."""
    return Path(__file__).resolve().parents[2]


def logs_path() -> Path:
    """Return the path used by the generated log commands."""
    return project_root() / LOGS_DIRECTORY / LOG_FILE_NAME


def configure_logging() -> None:
    """Configure application file logging."""
    path = logs_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    logger.setLevel(logging.INFO)
    for handler in list(logger.handlers):
        if isinstance(handler, logging.FileHandler) and Path(handler.baseFilename) == path:
            if path.exists():
                return
            logger.removeHandler(handler)
            handler.close()
    handler = logging.FileHandler(path)
    handler.setFormatter(logging.Formatter(LOG_FORMAT))
    logger.addHandler(handler)


{% if config_enabled == "true" -%}
def config_path() -> Path:
    """Return the generated config file path."""
    return project_root() / CONFIG_DIRECTORY / CONFIG_FILE_NAME


{% endif -%}
def non_negative_int(value: str) -> int:
    """Parse a non-negative line count."""
    count = int(value)
    if count < 0:
        raise argparse.ArgumentTypeError("--lines must be non-negative")
    return count


def read_new_lines(path: Path, offset: int) -> tuple[list[str], int]:
    """Read complete lines from offset, tolerating a missing log file."""
    if not path.exists():
        return [], 0
    with path.open() as file:
        file.seek(offset)
        lines = file.read().splitlines()
        return lines, file.tell()


def print_tail(path: Path, lines: int) -> int:
    """Print the requested trailing log lines and return the follow offset."""
    if not path.exists():
        return 0
    with path.open() as file:
        content = file.read().splitlines()
        for line in content[-lines:] if lines > 0 else []:
            print(line, flush=True)
        return file.tell()


def _show_logs_path(_args: argparse.Namespace) -> int:
    print(logs_path())
    return 0


{% if config_enabled == "true" -%}
def _show_config_path(_args: argparse.Namespace) -> int:
    print(config_path())
    return 0


{% endif -%}
def _show_logs(args: argparse.Namespace) -> int:
    path = logs_path()
    offset = print_tail(path, args.lines)
    if args.follow:
        while True:
            new_lines, offset = read_new_lines(path, offset)
            for line in new_lines:
                print(line, flush=True)
            time.sleep(0.1)
    return 0


def _calculate(args: argparse.Namespace) -> int:
    print(add(args.left, args.right).result)
    return 0


def build_parser() -> argparse.ArgumentParser:
    """Build the CLI parser."""
    parser = argparse.ArgumentParser(
        prog="{{ project_slug }}",
        description={{ description | tojson }},
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    logs_parser = subparsers.add_parser("show-logs", help="Print recent application logs.")
    logs_parser.add_argument(
        "--lines", type=non_negative_int, default=10, help="Number of trailing lines to print."
    )
    logs_parser.add_argument("--follow", action="store_true", help="Wait for new log lines.")
    logs_parser.set_defaults(handler=_show_logs)

    path_parser = subparsers.add_parser("show-logs-path", help="Print the application log path.")
    path_parser.set_defaults(handler=_show_logs_path)
    calculate_parser = subparsers.add_parser("calculate", help="Add two integers.")
    calculate_parser.add_argument("left", type=int)
    calculate_parser.add_argument("right", type=int)
    calculate_parser.set_defaults(handler=_calculate)
{% if config_enabled == "true" %}
    config_parser = subparsers.add_parser("show-config-path", help="Print the config file path.")
    config_parser.set_defaults(handler=_show_config_path)
{% endif %}
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    """Run the CLI."""
    configure_logging()
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.handler(args)
