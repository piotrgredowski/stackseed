{% endif -%}
def non_negative_int(_ctx: click.Context, _param: click.Parameter, value: int) -> int:
    """Validate a non-negative line count."""
    if value < 0:
        raise click.BadParameter("must be non-negative")
    return value


def read_new_lines(path: Path, offset: int) -> tuple[list[str], int]:
    """Read complete lines from offset, tolerating a missing log file."""
    if not path.exists():
        return [], 0
    with path.open() as file:
        file.seek(offset)
        lines = file.read().splitlines()
        return lines, file.tell()


def print_tail(path: Path, lines: int) -> int:
    """Print the requested trailing log lines and return the follow offset."""
    if not path.exists():
        return 0
    with path.open() as file:
        content = file.read().splitlines()
        for line in content[-lines:] if lines > 0 else []:
            click.echo(line)
        return file.tell()


@click.group(help={{ description | tojson }})
def app() -> None:
    """Run the command group."""


@app.command("show-logs")
@click.option(
    "--lines",
    default=10,
    show_default=True,
    type=int,
    callback=non_negative_int,
    help="Number of trailing lines to print.",
)
@click.option("--follow", is_flag=True, help="Wait for new log lines.")
def show_logs(lines: int, follow: bool) -> None:
    """Print recent application logs."""
    path = logs_path()
    offset = print_tail(path, lines)
    if follow:
        while True:
            new_lines, offset = read_new_lines(path, offset)
            for line in new_lines:
                click.echo(line)
            time.sleep(0.1)


@app.command("show-logs-path")
def show_logs_path() -> None:
    """Print the application log path."""
    click.echo(logs_path())


{% if config_enabled == "true" -%}
@app.command("show-config-path")
def show_config_path() -> None:
    """Print the config file path."""
    click.echo(config_path())


{% endif -%}
@app.command("calculate")
@click.argument("left", type=int)
@click.argument("right", type=int)
def calculate(left: int, right: int) -> None:
    """Add two integers."""
    click.echo(add(left, right).result)


def main() -> None:
    """Run the CLI."""
    configure_logging()
    app()
