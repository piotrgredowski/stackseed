import {{ project_slug | replace('-', '_') }} as package
from {{ project_slug | replace('-', '_') }}.calculator import add


def test_package_exposes_version() -> None:
    assert package.__version__ == "0.1.0"


def test_calculator_adds_two_integers() -> None:
    assert add(2, 3).result == 5


{% if backend_mode == "cli" and python_cli_framework == "argparse" -%}
def test_argparse_cli_help_lists_log_commands(capsys: CaptureFixture[str]) -> None:
    try:
        main(["--help"])
    except SystemExit as exc:
        assert exc.code == 0
    output = capsys.readouterr().out
    assert "show-logs" in output
    assert "show-logs-path" in output
    assert "calculate" in output


def test_argparse_cli_calculate_outputs_sum(capsys: CaptureFixture[str]) -> None:
    assert main(["calculate", "2", "3"]) == 0
    assert capsys.readouterr().out.strip() == "5"


def test_cli_logging_configures_application_log_file() -> None:
    assert LOGS_DIRECTORY == "logs"
    assert LOG_FILE_NAME == f"{APPLICATION_NAME}.log"
    path = logs_path()
    path.unlink(missing_ok=True)

    configure_logging()
    logger.info("test log entry")
    for handler in logger.handlers:
        handler.flush()

    assert path.is_file()
    assert "test log entry" in path.read_text()
