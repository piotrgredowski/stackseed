const applicationName = "{{ project_slug }}"
const logsDirectory = "logs"
const logFileName = applicationName + ".log"

{% endif -%}

var appLogger = log.New(io.Discard, "", log.LstdFlags)

func main() {
	if err := configureLogger(); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	rootCmd := newRootCommand()
	if err := rootCmd.Execute(); err != nil {
		os.Exit(1)
	}
}

func newRootCommand() *cobra.Command {
	rootCmd := &cobra.Command{
		Use:   "{{ project_slug }}",
		Short: {{ description | tojson }},
		Run: func(cmd *cobra.Command, args []string) {
			fmt.Fprintln(cmd.OutOrStdout(), {{ project_slug|replace('-', '_') }}.Greeting(""))
		},
	}
	rootCmd.AddCommand(newShowLogsPathCommand())
	rootCmd.AddCommand(newShowLogsCommand())
	rootCmd.AddCommand(newCalculateCommand())
{% if frontend == "solid_tailwind_shadcn" %}
	rootCmd.AddCommand(newServeCommand())
{% endif -%}
{% if config_enabled == "true" %}
	rootCmd.AddCommand(newShowConfigPathCommand())
{% endif %}
	return rootCmd
}

func newShowLogsPathCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "show-logs-path",
		Short: "Print the application log file path",
		Run: func(cmd *cobra.Command, args []string) {
			fmt.Fprintln(cmd.OutOrStdout(), logPath())
		},
	}
}

func newShowLogsCommand() *cobra.Command {
	var follow bool
	var lines int
	command := &cobra.Command{
		Use:   "show-logs",
		Short: "Print recent application logs",
		RunE: func(cmd *cobra.Command, args []string) error {
			if lines < 0 {
				return fmt.Errorf("--lines must be non-negative")
			}
			offset, err := printTail(cmd.OutOrStdout(), logPath(), lines)
			if err != nil {
				return err
			}
			if follow {
				for {
					var lines []string
					lines, offset, err = readNewLines(logPath(), offset)
					if err != nil {
						return err
					}
					for _, line := range lines {
						fmt.Fprintln(cmd.OutOrStdout(), line)
					}
					time.Sleep(100 * time.Millisecond)
				}
			}
			return nil
		},
	}
	command.Flags().BoolVar(&follow, "follow", false, "stream appended log lines")
	command.Flags().IntVar(&lines, "lines", 10, "number of trailing log lines to print")
	return command
}

func newCalculateCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "calculate LEFT RIGHT",
		Short: "Add two integers",
		Args:  cobra.ExactArgs(2),
		RunE: func(cmd *cobra.Command, args []string) error {
			left, err := strconv.Atoi(args[0])
			if err != nil {
				return err
			}
			right, err := strconv.Atoi(args[1])
			if err != nil {
				return err
			}
			fmt.Fprintln(cmd.OutOrStdout(), {{ project_slug|replace('-', '_') }}.Add(left, right))
			return nil
		},
	}
}

{% if frontend == "solid_tailwind_shadcn" -%}
func newServeCommand() *cobra.Command {
	return &cobra.Command{
		Use:   "serve",
		Short: "Run the backend API server",
		RunE: func(cmd *cobra.Command, args []string) error {
			return serveAPI()
		},
	}
}

func serveAPI() error {
	mux := http.NewServeMux()
	mux.HandleFunc("POST /api/calculate", {{ project_slug|replace('-', '_') }}.CalculateHandler)
	mux.HandleFunc("GET /healthz", {{ project_slug|replace('-', '_') }}.HealthHandler)
	return http.ListenAndServe(apiAddress(), mux)
}

func apiAddress() string {
	if address := os.Getenv("API_ADDRESS"); address != "" {
		return address
	}
	return "127.0.0.1:8080"
}

