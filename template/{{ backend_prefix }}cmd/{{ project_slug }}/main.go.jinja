{% endif -%}
func logPath() string {
	if directory := os.Getenv("APP_LOG_DIR"); directory != "" {
		return filepath.Join(directory, logFileName)
	}
	return filepath.Join(projectRoot(), logsDirectory, logFileName)
}

{% if config_enabled == "true" -%}
func configPath() string {
	return filepath.Join(projectRoot(), configDirectory, configFileName)
}

{% endif -%}
func configureLogger() error {
	path := logPath()
	if err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {
		return err
	}
	file, err := os.OpenFile(path, os.O_CREATE|os.O_APPEND|os.O_WRONLY, 0o644)
	if err != nil {
		return err
	}
	appLogger.SetOutput(file)
	appLogger.SetPrefix("[" + applicationName + "] ")
	return nil
}

func projectRoot() string {
	_, file, _, ok := runtime.Caller(0)
	if !ok {
		wd, err := os.Getwd()
		if err != nil {
			return "."
		}
		return wd
	}
	return filepath.Clean(filepath.Join(filepath.Dir(file), "..", ".."))
}

func printTail(writer io.Writer, path string, count int) (int64, error) {
	if count < 0 {
		return 0, fmt.Errorf("--lines must be non-negative")
	}
	file, err := os.Open(path)
	if os.IsNotExist(err) {
		return 0, nil
	}
	if err != nil {
		return 0, err
	}
	defer file.Close()

	scanner := bufio.NewScanner(file)
	var lines []string
	for scanner.Scan() {
		lines = append(lines, scanner.Text())
	}
	if err := scanner.Err(); err != nil {
		return 0, err
	}
	start := 0
	if count > 0 && len(lines) > count {
		start = len(lines) - count
	}
	if count == 0 {
		start = len(lines)
	}
	for _, line := range lines[start:] {
		fmt.Fprintln(writer, line)
	}
	offset, err := file.Seek(0, io.SeekCurrent)
	if err != nil {
		return 0, err
	}
	return offset, nil
}

func readNewLines(path string, offset int64) ([]string, int64, error) {
	file, err := os.Open(path)
	if os.IsNotExist(err) {
		return nil, 0, nil
	}
	if err != nil {
		return nil, offset, err
	}
	defer file.Close()
	if _, err := file.Seek(offset, io.SeekStart); err != nil {
		return nil, offset, err
	}
	scanner := bufio.NewScanner(file)
	var lines []string
	for scanner.Scan() {
		lines = append(lines, scanner.Text())
	}
	if err := scanner.Err(); err != nil {
		return nil, offset, err
	}
	newOffset, err := file.Seek(0, io.SeekCurrent)
	if err != nil {
		return nil, offset, err
	}
	return lines, newOffset, nil
}

func init() {
	cobra.EnableCommandSorting = false
}
